MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/horsetrack?retryWrites=true&w=majority
PORT=3000
JWT_SECRET=<random-32-char-string>
JWT_EXPIRES_IN=7d
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=10000

# PayOS
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_RETURN_URL=http://localhost:3001/payment/success
PAYOS_CANCEL_URL=http://localhost:3001/payment/cancel

# AI Engine Config
AI_MIN_REST_DAYS=3
AI_STRENGTH_SPREAD_THRESHOLD=15
